# Runtime
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=replace_with_secure_random
REFRESH_TOKEN_SECRET=replace_with_secure_random
JWT_ALG=HS256
JWT_ISSUER=
JWT_AUDIENCE=
BCRYPT_ROUNDS=10

# CORS
PUBLIC_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ALL=false
CORS_ALLOW_NULL=false

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=sistema_gestion
MYSQL_USER=root
MYSQL_PASSWORD=
DB_POOL_SIZE=10
DB_MIGRATIONS_DIR=../database/migrations_mysql

# AI python bridge (optional)
LOCAL_AI_URL=http://localhost:8000
AI_PY_FORECAST=true
AI_PY_PRICING=true

# LLM bridge
AI_LLM_ENABLED=false
AI_PROVIDER_ORDER=local,openai,gemini,deepseek
