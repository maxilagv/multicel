# Runtime
NODE_ENV=development
PORT=3000
APP_VERSION=dev-local

# Auth
JWT_SECRET=replace_with_secure_random
REFRESH_TOKEN_SECRET=replace_with_secure_random
JWT_ALG=HS256
JWT_ISSUER=
JWT_AUDIENCE=
BCRYPT_ROUNDS=10

# CORS
PUBLIC_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ALL=false
CORS_ALLOW_NULL=false

# WhatsApp -- proveedor activo (valores: web | twilio | off)
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=web
WHATSAPP_DISPATCHER_ENABLED=true
WHATSAPP_DISPATCHER_INTERVAL_MS=10000
WHATSAPP_DISPATCHER_BATCH_SIZE=25

# WhatsApp Web / Baileys
WHATSAPP_WEB_SESSION_NAME=default
WHATSAPP_RECONNECT_BASE_MS=5000
WHATSAPP_RECONNECT_MAX_MS=60000
WHATSAPP_QR_SCALE=6
WHATSAPP_ORPHAN_LOCK_MINUTES=5
WHATSAPP_MAX_ATTEMPTS=5

# WhatsApp oficial / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SKIP_SIGNATURE_VALIDATION=false

# Automatizaciones / n8n
AUTOMATION_EVENTS_ENABLED=true
AUTOMATION_EVENTS_INTERVAL_MS=10000
AUTOMATION_EVENTS_BATCH_SIZE=20
AUTOMATION_EVENTS_ORPHAN_LOCK_MINUTES=5
N8N_BASE_URL=
N8N_WEBHOOK_TOKEN=
N8N_TIMEOUT_MS=8000
INTERNAL_API_TOKEN=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=sistema_gestion
MYSQL_USER=root
MYSQL_PASSWORD=
DB_POOL_SIZE=10
DB_POOL_MAX_IDLE=10
DB_POOL_IDLE_TIMEOUT_MS=60000
DB_CONNECT_TIMEOUT_MS=10000
DB_ACQUIRE_TIMEOUT_MS=30000
DB_KEEPALIVE=true
DB_KEEPALIVE_INITIAL_DELAY_MS=10000
DB_MIGRATIONS_DIR=../database/migrations_mysql

# Runtime store / Redis (optional, fallback to memory when unavailable)
REDIS_URL=
REDIS_KEY_PREFIX=kaisen

# Sales aggregates
SALES_AGGREGATES_REFRESH_MS=3600000
SALES_AGGREGATES_LOOKBACK_DAYS=120
SALES_AGGREGATES_STALE_AFTER_MINUTES=60

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_OTP_MAX=10
RATE_LIMIT_OTP_WINDOW_MS=600000
RATE_LIMIT_REFRESH_MAX=20
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_MAX=20
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_EXPORT_MAX=3
RATE_LIMIT_EXPORT_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=30
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# ARCA / Facturación electrónica AFIP
# ARCA_SANDBOX=true → simula CAEs sin llamar a AFIP (para testing/desarrollo)
# En producción: false (requiere certificado P12 + CUIT + clave fiscal nivel 2)
ARCA_SANDBOX=true

# AI python bridge (optional)
LOCAL_AI_URL=http://localhost:8000
AI_PY_FORECAST=true
AI_PY_PRICING=true

# LLM bridge — Gemini es el proveedor principal
AI_LLM_ENABLED=true
AI_PROVIDER_ORDER=gemini,openai,deepseek,local
GEMINI_API_KEY=
# Dejalo vacio para autodetectar un modelo compatible con tu API key.
# Si queres fijarlo manualmente, usa un nombre exacto devuelto por GET /api/chat/models.
GEMINI_MODEL=
GEMINI_CHAT_MODEL=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_COMPLETIONS_URL=
DEEPSEEK_MODEL=deepseek-chat

# Chat IA (asistente conversacional)
AI_CHAT_TIMEOUT_MS=30000

# ── MercadoPago ────────────────────────────────────────────────────────────────
# El Access Token lo ingresa el cliente desde el panel /app/integraciones.
# NO se configura aquí en producción — se guarda encriptado en la base de datos.
# URL base de la API (no cambiar salvo entorno de pruebas custom)
MP_API_BASE_URL=https://api.mercadopago.com
# Timeout para requests HTTP a MP (ms)
MP_HTTP_TIMEOUT_MS=15000

# ── MercadoLibre OAuth 2.0 ─────────────────────────────────────────────────────
# Registrá tu aplicación en: https://developers.mercadolibre.com.ar/es_ar/registra-tu-aplicacion
# El Client ID y Secret son credenciales del OPERADOR (no del cliente final).
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el Redirect URI registrado en la consola de ML.
# Desarrollo: http://localhost:3000/api/integraciones/ml/callback
# Producción:  https://tu-dominio.com/api/integraciones/ml/callback
ML_REDIRECT_URI=http://localhost:3000/api/integraciones/ml/callback
# Secreto para firmar el state JWT del flujo OAuth (usa JWT_SECRET si se deja vacío)
ML_STATE_SECRET=
# URL base de la API y de auth (no cambiar salvo entorno custom)
ML_API_BASE_URL=https://api.mercadolibre.com
ML_AUTH_BASE_URL=https://auth.mercadolibre.com.ar
# Timeout para requests HTTP a ML (ms)
ML_HTTP_TIMEOUT_MS=15000
# Valores por defecto para publicaciones en ML
ML_DEFAULT_LISTING_TYPE=gold_special
ML_DEFAULT_CONDITION=new
ML_DEFAULT_BUYING_MODE=buy_it_now
ML_DEFAULT_CURRENCY_ID=ARS

# AI gateway y policy engine enterprise
AI_DATA_GATEWAY_URL=http://localhost:3000/api
AI_DATA_GATEWAY_TIMEOUT_SECONDS=8
AI_COMPANY_ID=
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires
AI_POLICY_BUSINESS_HOUR_START=8
AI_POLICY_BUSINESS_HOUR_END=20
AI_POLICY_ENTITY_COOLDOWN_DAYS=7
AI_POLICY_MAX_AUTOMATIONS_PER_ENTITY=2
AI_POLICY_HIGH_BALANCE_THRESHOLD=250000
AI_AGENT_RUNTIME_ENABLED=true
AI_AGENT_SESSION_ENABLED=true
AI_AGENT_CHAT_BRIDGE_ENABLED=true
AI_AGENT_SURFACES_ENABLED=true
AI_AGENT_KILL_SWITCH=false
AI_AGENT_SHADOW_MODE=false
AI_AGENT_ACTION_GATES_STRICT=true
AI_AGENT_DISABLED_LANES=
AI_AGENT_DISABLED_ACTION_TYPES=
AI_AGENT_AUTOMATION_HOURS=8-20
AI_AGENT_MAX_AUTOMATIONS_PER_HOUR=25
AI_AGENT_MAX_AUTOMATIONS_PER_DAY=120
AI_AGENT_MAX_AUTOMATIONS_PER_ACTION_PER_DAY=40
AI_AGENT_ALERT_DEGRADED_RUNS_24H=8
AI_AGENT_ALERT_FAILED_EXECUTIONS_24H=5
AI_AGENT_ALERT_PENDING_EXECUTIONS_24H=12
