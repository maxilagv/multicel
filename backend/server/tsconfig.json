{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "baseUrl": "."
  },
  "include": [
    "index.js",
    "controllers/**/*.js",
    "db/**/*.js",
    "middlewares/**/*.js",
    "routes/**/*.js",
    "services/**/*.js",
    "scripts/**/*.js",
    "__tests__/**/*.js",
    "docs/**/*.js"
  ]
}
