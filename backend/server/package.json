{
  "name": "servidor",
  "version": "1.0.0",
  "description": "Servidor seguro para aplicacion de muebleria",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles",
    "dev": "nodemon index.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "migrate": "node scripts/migrate.js",
    "gen-hash": "node scripts/gen-hash.js",
    "set-admin-password": "node scripts/set-admin-password.js",
    "bootstrap-admin": "node scripts/bootstrap-admin.js"
  },
  "keywords": [
    "express",
    "seguridad",
    "jwt",
    "api"
  ],
  "author": "Maximo Lavagetto",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^7.7.0",
    "@sentry/node": "^10.42.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "fast-xml-parser": "^4.5.3",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.2",
    "nodemailer": "^7.0.6",
    "otplib": "^13.3.0",
    "pdfkit": "^0.13.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "xss-clean": "^0.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2"
  }
}
